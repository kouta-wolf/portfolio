---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Social from '../components/Social.astro';
import Footer from '../components/Footer.astro';
import TocRibbon from '../components/TocRibbon.astro';
import { Portfolio } from '../components/Portfolio';

const projectEntries = (await getCollection('projects', ({ data }) => data.featured)).sort(
	(a, b) => a.data.order - b.data.order,
);
const projects = projectEntries.map((entry) => ({
	slug: entry.id,
	title: entry.data.title,
	description: entry.data.description,
	githubUrl: entry.data.githubUrl,
	renderUrl: entry.data.renderUrl,
	techStack: entry.data.techStack,
	imageSrc: entry.data.image?.src,
}));
---

<Layout title="HexWolf Portfolio">
	<Header />
	<TocRibbon />
	<main class="h-dvh w-screen overflow-hidden">
		<div class="flex h-full w-full transition-transform duration-400 ease-in-out" data-chapters-row>
			<Hero />
			<About />
			<Portfolio client:load projects={projects} />
			<Social />
		</div>
	</main>
	<Footer />
</Layout>

<script>
	import { $activeChapterId, $chapters } from '../stores/book';

	const row = document.querySelector<HTMLElement>('[data-chapters-row]');

	const applyRowOffset = () => {
		if (!row) return;
		const chapters = $chapters.get();
		const active = chapters.find((chapter) => chapter.id === $activeChapterId.get());
		if (!active) return;
		row.style.transform = `translateX(-${active.order * 100}%)`;
	};

	$activeChapterId.subscribe(applyRowOffset);
	applyRowOffset();
</script>
