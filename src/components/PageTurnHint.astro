<button
	type="button"
	aria-label="次のセクションへスクロール"
	class="fixed bottom-6 right-6 z-40 h-12 w-12 cursor-pointer border-0 bg-transparent p-0"
	onclick="window.scrollBy({ top: window.innerHeight, behavior: 'smooth' })"
>
	<span
		class="block h-full w-full bg-accent/80 shadow-md transition hover:bg-accent"
		style="clip-path: polygon(100% 0, 100% 100%, 0 100%);"
	></span>
</button>
