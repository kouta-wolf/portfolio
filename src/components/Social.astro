---
import BookCard from './BookCard.astro';

const links = [
	{ label: 'GitHub', href: 'https://github.com/kouta-wolf' },
	{ label: 'X', href: 'https://x.com/o_kami_code' },
	{ label: 'Zenn', href: 'https://zenn.dev/ookami_dev' },
];
---

<BookCard chapterId="social">
	<h2 class="font-heading text-3xl font-bold border-b-2 border-accent pb-1">第三章 連絡先</h2>
	<p class="mt-4">現場から飛び出して、今はコードで人とつながっています。お気軽にどうぞ。</p>
	<div class="mt-8 flex flex-col gap-4">
		{
			links.map((link) => (
				<a
					href={link.href}
					target="_blank"
					rel="noopener noreferrer"
					class="bg-accent text-bg rounded px-4 py-2 text-center transition hover:opacity-90"
				>
					{link.label}
				</a>
			))
		}
	</div>
</BookCard>
