---
interface Props {
	chapterId: string;
	decorationSrc?: string;
}

const { chapterId, decorationSrc } = Astro.props;
---

<section
	class="chapter-slide relative flex items-center justify-center p-4 md:p-8"
	data-chapter={chapterId}
>
	<div class="paper relative h-full w-full max-w-6xl overflow-hidden rounded-lg shadow-2xl">
		<div
			class="pointer-events-none absolute inset-y-0 left-1/2 hidden w-6 -translate-x-1/2 bg-gradient-to-r from-black/15 via-black/25 to-black/15 blur-sm md:block"
		>
		</div>
		<div class="pointer-events-none absolute inset-y-0 left-1/2 hidden w-px -translate-x-1/2 bg-black/20 md:block"></div>
		{
			decorationSrc && (
				<img
					src={decorationSrc}
					alt=""
					class="pointer-events-none absolute inset-0 m-auto h-1/3 w-1/3 opacity-15"
				/>
			)
		}
		<div class="spread-row h-full" data-book-spread>
			<div class="spread-page h-full overflow-hidden p-8 leading-loose md:px-16 md:py-12">
				<slot name="page1" />
			</div>
			<div class="spread-page h-full overflow-hidden p-8 leading-loose md:px-16 md:py-12">
				<slot name="page2" />
			</div>
		</div>
	</div>
</section>

<script>
	import { $activeChapterId, $innerIndex, setChapterPageCount } from '../stores/book';

	document.querySelectorAll<HTMLElement>('[data-book-spread]').forEach((row) => {
		const chapterId = row.closest<HTMLElement>('[data-chapter]')?.dataset.chapter;
		if (!chapterId) return;

		setChapterPageCount(chapterId, 2);

		const update = () => {
			if ($activeChapterId.get() !== chapterId) return;
			row.style.setProperty('--page-offset', String($innerIndex.get()));
		};

		$activeChapterId.subscribe(update);
		$innerIndex.subscribe(update);
	});
</script>
