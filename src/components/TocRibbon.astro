---
const links = [
	{ label: '序章', chapterId: 'hero' },
	{ label: '第一章 プロフィール', chapterId: 'about' },
	{ label: '第二章 作品集', chapterId: 'portfolio' },
	{ label: '第三章 連絡先', chapterId: 'social' },
];
---

<div class="group fixed top-4 right-4 z-40 flex flex-row-reverse items-stretch md:top-1/2 md:right-auto md:left-0 md:flex-row md:-translate-y-1/2">
	<input type="checkbox" id="toc-toggle" class="peer sr-only" />
	<label
		for="toc-toggle"
		aria-label="目次"
		class="bg-accent text-bg flex h-10 w-10 shrink-0 cursor-pointer items-center justify-center rounded-full text-xl leading-none shadow-lg md:h-auto md:w-8 md:rounded-l-none md:rounded-r-md md:py-6 md:text-sm md:shadow-none"
	>
		<span class="md:hidden" aria-hidden="true">&#9776;</span>
		<span class="hidden font-heading tracking-widest md:inline md:[writing-mode:vertical-rl]">目次</span>
	</label>
	<nav
		aria-label="目次"
		class="bg-paper-bg text-paper-text mr-2 flex w-0 flex-col justify-center gap-3 overflow-hidden rounded-md p-0 whitespace-nowrap shadow-lg transition-[width,padding] duration-250 ease-out group-hover:w-48 group-hover:p-4 peer-checked:w-48 peer-checked:p-4 md:mr-0 md:rounded-l-none md:rounded-r-md"
	>
		{
			links.map((link) => (
				<a href={`#${link.chapterId}`} data-chapter-link={link.chapterId} class="hover:text-accent">
					{link.label}
				</a>
			))
		}
	</nav>
</div>
