---
const links = [
	{ label: '序章', chapterId: 'hero' },
	{ label: '第一章 プロフィール', chapterId: 'about' },
	{ label: '第二章 作品集', chapterId: 'portfolio' },
	{ label: '第三章 連絡先', chapterId: 'social' },
];
---

<div class="group fixed top-1/2 left-0 z-40 flex -translate-y-1/2 items-stretch">
	<input type="checkbox" id="toc-toggle" class="peer sr-only" />
	<label
		for="toc-toggle"
		class="bg-accent text-bg flex w-8 shrink-0 cursor-pointer items-center justify-center rounded-r-md py-6 font-heading text-sm tracking-widest [writing-mode:vertical-rl]"
	>
		目次
	</label>
	<nav
		aria-label="目次"
		class="bg-paper-bg text-paper-text flex w-0 flex-col justify-center gap-3 overflow-hidden rounded-r-md p-0 whitespace-nowrap shadow-lg transition-[width,padding] duration-250 ease-out group-hover:w-48 group-hover:p-4 peer-checked:w-48 peer-checked:p-4"
	>
		{
			links.map((link) => (
				<a href={`#${link.chapterId}`} data-chapter-link={link.chapterId} class="hover:text-accent">
					{link.label}
				</a>
			))
		}
	</nav>
</div>
